# Supabase — progetto → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — NON esporre mai al client, solo Vercel env vars
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Chiave Groq server-side — usata dal proxy /api/groq
# Ottienila su console.groq.com → API Keys
GROQ_API_KEY=your-groq-api-key

# Opzionale: chiave Groq lato client (fallback per sviluppo locale)
# VITE_GROQ_API_KEY=your-groq-api-key
